/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    OpenGenome reference workflow test profile
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Defines bounded resources for local smoke tests. Test data paths are still supplied
    by scripts/check-genomics.sh until the micro dataset is promoted into assets/.
----------------------------------------------------------------------------------------
*/

process {
  cpus = 2
  memory = '4 GB'
}

executor {
  queueSize = 2
}
